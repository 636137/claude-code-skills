def _params(event):
    out = {}
    for p in event.get("parameters", []) or []:
        out[p["name"]] = p.get("value")
    if not out and event.get("requestBody"):
        for _mime, body in (event["requestBody"].get("content") or {}).items():
            for p in body.get("properties", []) or []:
                out[p["name"]] = p.get("value")
    return out


