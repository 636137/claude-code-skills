{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "{{ blueprint.description | default(blueprint.name + ' blueprint') }}",
  "class": "{{ blueprint.class | default(blueprint.name) }}",
  "type": "object",
  "definitions": {},
  "properties": {
{%- for fname, fdef in blueprint.fields.items() %}
    "{{ fname }}": {
      "type": "{{ fdef.type | default('string') }}",
      "inferenceType": "{{ fdef.inferenceType | default('explicit') }}",
      "instruction": "{{ fdef.instruction | replace('"', '\\"') }}"
    }{% if not loop.last %},{% endif %}
{%- endfor %}
  }
}
